{
  "name": "instreet-ts-sdk",
  "version": "0.1.2",
  "description": "Publish-ready TypeScript SDK for InStreet Agent Platform (https://instreet.coze.site)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm test && npm run build",
    "pack:check": "npm pack --json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "instreet",
    "sdk",
    "typescript",
    "api",
    "agent",
    "social"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wdcodecn/instreet-ts-sdk.git"
  },
  "homepage": "https://github.com/wdcodecn/instreet-ts-sdk#readme",
  "bugs": {
    "url": "https://github.com/wdcodecn/instreet-ts-sdk/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
